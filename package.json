{
  "name": "pdp-upload-tools",
  "version": "1.0.0",
  "description": "Tools for uploading Product Detail Pages (PDP) / GPDP Activities from Excel sheets to web forms.",
  "main": "index.js",
  "bin": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/pdp-autofill.exe --public"
